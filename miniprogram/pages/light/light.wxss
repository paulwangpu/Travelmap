.content-page {
  min-height: 100%;
  padding: 0 22rpx 34rpx;
  background: #f4f7f4;
}

.page-head {
  margin-bottom: 18rpx;
  padding-top: calc(env(safe-area-inset-top) + 72rpx);
}

.view-tabs {
  position: sticky;
  z-index: 10;
  top: calc(env(safe-area-inset-top) + 68rpx);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 4rpx;
  margin-bottom: 14rpx;
  padding: 5rpx;
  border: 1rpx solid #cfd8d2;
  border-radius: 8rpx;
  background: rgba(244, 247, 244, 0.96);
}

.view-tab {
  display: flex;
  min-width: 0;
  min-height: 66rpx;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  border-radius: 6rpx;
  color: #56635d;
  font-size: 24rpx;
  font-weight: 800;
}

.view-tab.active {
  background: #17231f;
  color: #ffffff;
}

.view-count {
  font-size: 18rpx;
  opacity: 0.72;
}

.eyebrow,
.page-title,
.section-title,
.chip-name,
.chip-status {
  display: block;
}

.eyebrow {
  margin-bottom: 6rpx;
  color: #208765;
  font-size: 20rpx;
  font-weight: 800;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.15;
}

.panel {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-head,
.group-summary,
.manual-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-head {
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.tag {
  flex: 0 0 auto;
  padding: 7rpx 11rpx;
  border-radius: 999rpx;
  background: #e4ece7;
  color: #163f38;
  font-size: 21rpx;
  font-weight: 800;
}

.manual-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.manual-groups {
  display: grid;
  gap: 12rpx;
}

.city-tools {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin: -2rpx 0 14rpx;
  color: #69766f;
  font-size: 21rpx;
}

.city-tools button {
  flex: 0 0 auto;
  min-height: 52rpx;
  padding: 0 16rpx;
  border: 1rpx solid #c9d3cd;
  border-radius: 6rpx;
  background: #ffffff;
  color: #23463c;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 50rpx;
}

.city-tools button::after {
  border: 0;
}

.manual-group {
  padding: 14rpx 16rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
}

.group-summary {
  min-height: 44rpx;
}

.group-name {
  font-weight: 900;
}

.group-count {
  color: #64716a;
  font-size: 21rpx;
  font-weight: 800;
}

.manual-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 14rpx;
}

.group-grid {
  margin-top: 14rpx;
}

.manual-chip {
  min-width: 0;
  min-height: 76rpx;
  gap: 8rpx;
  padding: 12rpx 14rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
  color: #18201c;
  text-align: left;
}

.manual-chip::after {
  border: 0;
}

.manual-chip.done {
  border-color: #8cb69a;
  background: #f1fbf4;
}

.manual-chip[disabled] {
  opacity: 0.82;
}

.list-chip {
  width: 100%;
  min-height: 64rpx;
  border-radius: 6rpx;
}

@media (min-width: 500px) {
  .manual-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

.chip-name {
  min-width: 0;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
}

.chip-status {
  flex: 0 0 auto;
  color: #64716a;
  font-size: 19rpx;
  font-weight: 800;
  white-space: nowrap;
}
