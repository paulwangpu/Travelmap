.imports-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 40rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 5rpx;
  color: #64716a;
  font-size: 22rpx;
  font-weight: 800;
}

.import-panel {
  padding: 26rpx;
  border: 2rpx dashed #9fb1a7;
  border-radius: 12rpx;
  background: #ffffff;
  text-align: center;
}

.choose-button {
  width: 100%;
  line-height: 78rpx;
}

.format-row {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin-top: 16rpx;
}

.format-row text {
  padding: 6rpx 12rpx;
  border-radius: 7rpx;
  background: #e9f1ed;
  color: #17604e;
  font-size: 21rpx;
  font-weight: 800;
}

.privacy-note {
  display: block;
  margin-top: 14rpx;
  color: #748078;
  font-size: 21rpx;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.metrics > view {
  padding: 18rpx 8rpx;
  border: 1rpx solid #dce3de;
  border-radius: 10rpx;
  background: #ffffff;
  text-align: center;
}

.metric-value,
.metric-label,
.file-name,
.file-meta {
  display: block;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 5rpx;
  color: #6c7871;
  font-size: 21rpx;
}

.section-row,
.file-item {
  display: flex;
  align-items: center;
}

.section-row {
  justify-content: space-between;
}

.clear-button,
.delete-button {
  padding: 0 12rpx;
  background: transparent;
  color: #a43e32;
  font-size: 22rpx;
  line-height: 54rpx;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 9rpx;
}

.file-item {
  min-height: 96rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid #dce3de;
  border-radius: 10rpx;
  background: #ffffff;
}

.file-icon {
  width: 76rpx;
  color: #16735b;
  font-size: 20rpx;
  font-weight: 900;
}

.file-copy {
  flex: 1;
  min-width: 0;
}

.file-name {
  overflow: hidden;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  margin-top: 6rpx;
  color: #6c7871;
  font-size: 21rpx;
}

.data-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.action-row button {
  line-height: 68rpx;
}
