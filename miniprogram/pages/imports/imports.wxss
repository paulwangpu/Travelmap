.imports-page { min-height: 100vh; padding: calc(env(safe-area-inset-top) + 72rpx) 16rpx 150rpx; background: #f4f7f4; }
.panel { margin-bottom: 14rpx; padding: 20rpx; border: 1rpx solid #d7ded8; border-radius: 8rpx; background: #fff; }
.section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12rpx; margin-bottom: 18rpx; }
.eyebrow, .title, .help, .file-name, .file-meta, .value, .label { display: block; }
.eyebrow { color: #69766f; font-size: 22rpx; font-weight: 700; }
.title { margin-top: 3rpx; color: #17201c; font-size: 32rpx; font-weight: 800; }
.tag { flex: none; padding: 6rpx 10rpx; border-radius: 6rpx; background: #e8efeb; color: #496057; font-size: 19rpx; font-weight: 700; }
button { min-height: 66rpx; border: 1rpx solid #bfcac3; border-radius: 6rpx; background: #fff; color: #24322c; font-size: 25rpx; line-height: 64rpx; }
.primary-action { width: 100%; background: #176f58; color: #fff; border-color: #176f58; }
.help { margin-top: 14rpx; color: #68756e; font-size: 22rpx; line-height: 1.55; }
.archive-actions { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8rpx; }
.archive-actions button { padding: 0 6rpx; }
.archive-actions .danger-action { color: #a43e32; border-color: #d9aaa4; }
.file-list { margin-top: 14rpx; border-top: 1rpx solid #e1e6e2; }
.file-row { display: flex; align-items: center; gap: 10rpx; min-height: 86rpx; border-bottom: 1rpx solid #e1e6e2; }
.file-copy { flex: 1; min-width: 0; }
.file-name { overflow: hidden; font-size: 25rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.file-meta { margin-top: 4rpx; color: #718078; font-size: 21rpx; }
.text-danger { min-height: 50rpx; padding: 0 8rpx; border: 0; color: #a43e32; font-size: 22rpx; line-height: 50rpx; }
.inventory { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border: 1rpx solid #dce3de; border-radius: 7rpx; }
.inventory > view { padding: 18rpx; border-right: 1rpx solid #dce3de; border-bottom: 1rpx solid #dce3de; }
.inventory > view:nth-child(2n) { border-right: 0; }
.inventory > view:nth-last-child(-n+2) { border-bottom: 0; }
.value { font-size: 34rpx; font-weight: 800; }
.label { margin-top: 2rpx; color: #6b7770; font-size: 21rpx; }
.empty { padding: 36rpx 0 12rpx; color: #718078; font-size: 23rpx; text-align: center; }
