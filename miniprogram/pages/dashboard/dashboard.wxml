<view class="content-page">
  <view class="page-head">
    <text class="eyebrow">总览</text>
    <text class="page-title">旅行统计总览</text>
  </view>

  <view class="metrics-grid">
    <view wx:for="{{metrics}}" wx:key="key" class="metric">
      <text class="metric-value">{{item.value}}</text>
      <text class="metric-label">{{item.label}}</text>
    </view>
  </view>

  <view class="achievement-section">
    <view class="section-head achievement-head">
      <text class="section-title">核心打卡</text>
      <text class="tag" bindtap="openChecklist">查看清单</text>
    </view>
    <view class="achievement-list">
      <view wx:for="{{achievements}}" wx:key="key" class="achievement">
        <view
          class="achievement-ring"
          style="background: radial-gradient(circle at center, #fff 0 55%, transparent 57%), conic-gradient(#208765 {{item.percent}}%, #e1e7e2 0)"
        >
          <text>{{item.percent}}%</text>
        </view>
        <view class="achievement-body">
          <view class="achievement-title-row">
            <text class="achievement-name">{{item.name}}</text>
            <text class="achievement-status">{{item.status}}</text>
          </view>
          <text class="achievement-category">{{item.category}}</text>
          <text class="achievement-value">{{item.doneCount}}/{{item.total}}</text>
          <view class="bar"><view class="bar-value" style="width: {{item.percent}}%"></view></view>
        </view>
      </view>
    </view>
  </view>

  <view class="panel next-panel">
    <text class="section-title">下一步打卡导航</text>
    <view class="next-list">
      <view wx:for="{{nextStops}}" wx:key="key" class="next-card">
        <view class="next-title-row">
          <text class="next-title">{{item.title}}</text>
          <text class="tag" data-page="{{item.page}}" bindtap="openPage">{{item.action}}</text>
        </view>
        <text class="next-body">{{item.body}}</text>
      </view>
    </view>
  </view>
</view>
