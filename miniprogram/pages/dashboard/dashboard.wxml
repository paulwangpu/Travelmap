<view class="page dashboard-page">
  <view class="dashboard-head">
    <view>
      <text class="eyebrow">总览</text>
      <view class="page-title">旅行统计总览</view>
    </view>
    <button class="data-button" bindtap="openImports">导入</button>
  </view>

  <view class="metric-grid">
    <view wx:for="{{metrics}}" wx:key="key" class="metric">
      <text class="metric-value">{{item.value}}</text>
      <text class="metric-label">{{item.label}}</text>
    </view>
  </view>

  <view class="achievement-section">
    <view class="section-row">
      <view class="section-title">核心打卡等级</view>
      <button class="text-button" bindtap="openChecklists">查看清单</button>
    </view>
    <view class="achievement-list">
      <view wx:for="{{achievements}}" wx:key="key" class="achievement">
        <view class="achievement-percent">{{item.percent}}%</view>
        <view class="achievement-content">
          <view class="achievement-head">
            <text class="achievement-name">{{item.name}}</text>
            <text class="achievement-value">{{item.value}}</text>
          </view>
          <view class="progress-track">
            <view class="progress-value" style="width: {{item.percent}}%"></view>
          </view>
          <text class="achievement-note">{{item.note}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="next-section">
    <view class="section-title">下一步打卡导航</view>
    <view class="next-list">
      <view wx:for="{{nextStops}}" wx:key="key" class="next-item">
        <view>
          <text class="next-title">{{item.title}}</text>
          <text class="next-note">{{item.note}}</text>
        </view>
        <button class="next-button" data-page="{{item.page}}" bindtap="openPage">{{item.action}}</button>
      </view>
    </view>
  </view>
</view>
