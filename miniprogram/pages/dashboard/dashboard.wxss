.content-page {
  min-height: 100%;
  padding: calc(env(safe-area-inset-top) + 72rpx) 20rpx 20rpx;
  background: #f4f7f4;
}

.page-head {
  margin-bottom: 16rpx;
}

.eyebrow,
.page-title,
.metric-value,
.metric-label,
.achievement-category,
.achievement-value,
.next-body {
  display: block;
}

.eyebrow {
  margin-bottom: 5rpx;
  color: #208765;
  font-size: 20rpx;
  font-weight: 800;
}

.page-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.15;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric {
  min-height: 134rpx;
  padding: 20rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
}

.metric-value {
  margin-bottom: 10rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.metric-label {
  color: #64716a;
  font-size: 21rpx;
}

.achievement-section {
  margin-top: 18rpx;
}

.section-head,
.achievement-title-row,
.next-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.achievement-head {
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.tag {
  flex: 0 0 auto;
  padding: 7rpx 11rpx;
  border-radius: 999rpx;
  background: #e4ece7;
  color: #163f38;
  font-size: 20rpx;
  font-weight: 800;
}

.achievement-list {
  display: grid;
  gap: 10rpx;
}

.achievement {
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr);
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: linear-gradient(180deg, #ffffff, #f2f7f4);
}

.achievement-ring {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d7ded8;
  border-radius: 50%;
  color: #163f38;
  font-size: 20rpx;
  font-weight: 900;
}

.achievement-body {
  min-width: 0;
}

.achievement-name {
  font-size: 25rpx;
  font-weight: 900;
}

.achievement-status,
.achievement-category {
  color: #64716a;
  font-size: 19rpx;
  font-weight: 800;
}

.achievement-category {
  margin-top: 3rpx;
}

.achievement-value {
  margin: 5rpx 0;
  color: #163f38;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.bar {
  height: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e1e7e2;
}

.bar-value {
  height: 100%;
  background: #208765;
}

.panel {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
}

.next-list {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.next-card {
  padding: 16rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #f7f8f5;
}

.next-title {
  font-size: 24rpx;
  font-weight: 900;
}

.next-body {
  margin-top: 6rpx;
  overflow: hidden;
  color: #64716a;
  font-size: 20rpx;
  line-height: 1.4;
}
