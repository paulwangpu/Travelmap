.map-app {
  position: relative;
  height: 100%;
  min-height: 100%;
  overflow: hidden;
  background: #dfe9e7;
}

.travel-map {
  width: 100%;
  height: 100%;
}

.map-toolbar {
  position: absolute;
  z-index: 20;
  top: calc(env(safe-area-inset-top) + 36px);
  right: 8px;
  left: 8px;
  display: grid;
  gap: 5px;
  padding: 5px;
  border: 0;
  border-radius: 7px;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 6px 16px rgba(24, 32, 28, 0.12);
}

.map-title {
  display: none;
}

.map-control-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
  gap: 5px;
  align-items: end;
}

.map-select {
  display: block;
  min-height: 32px;
}

.control-label,
.control-value {
  display: block;
}

.control-label {
  display: none;
}

.control-value {
  height: 32px;
  padding: 0 8px;
  overflow: hidden;
  border: 0;
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.96);
  font-size: 12px;
  font-weight: 800;
  line-height: 32px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-add-point {
  width: auto;
  height: 32px;
  min-height: 32px;
  padding: 0 9px;
  border: 0;
  border-radius: 6px;
  background: #17231f;
  color: #ffffff;
  font-size: 12px;
  line-height: 32px;
  white-space: nowrap;
}

.map-add-point.active {
  background: #d9480f;
}

.map-add-point::after {
  border: 0;
}

.map-overlay-toggles {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 5px;
  overflow: visible;
}

.overlay-toggle {
  display: flex;
  min-width: 0;
  min-height: 25px;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 3px 4px;
  border: 1px solid #d7ded8;
  border-radius: 6px;
  background: #ffffff;
  font-size: 10px;
  font-weight: 800;
  white-space: nowrap;
}

.checkbox {
  display: flex;
  width: 13px;
  height: 13px;
  align-items: center;
  justify-content: center;
  border: 1px solid #9aa69f;
  border-radius: 2px;
  color: #ffffff;
  font-size: 9px;
  line-height: 1;
}

.checkbox.checked {
  border-color: #17231f;
  background: #17231f;
}

.map-mode-tip {
  position: absolute;
  z-index: 19;
  top: calc(env(safe-area-inset-top) + 110px);
  left: 50%;
  padding: 8px 12px;
  transform: translateX(-50%);
  border-radius: 8px;
  background: #17231f;
  color: #ffffff;
  font-size: 12px;
  font-weight: 800;
  white-space: nowrap;
}

.map-drawer {
  position: absolute;
  z-index: 30;
  right: 0;
  bottom: 0;
  left: 0;
  max-height: min(48vh, 390px);
  padding: 14px 16px calc(16px + env(safe-area-inset-bottom));
  overflow-y: auto;
  border-top: 1px solid rgba(23, 35, 31, 0.12);
  border-radius: 12px 12px 0 0;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 -14px 34px rgba(24, 32, 28, 0.18);
}

.drawer-close {
  position: absolute;
  top: 10px;
  right: 12px;
  display: flex;
  width: 28px;
  height: 28px;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(23, 35, 31, 0.12);
  border-radius: 999px;
  color: #26352f;
  font-size: 18px;
}

.eyebrow,
.drawer-title {
  display: block;
}

.eyebrow {
  margin-bottom: 5px;
  color: #208765;
  font-size: 11px;
  font-weight: 800;
}

.drawer-title {
  margin-right: 34px;
  margin-bottom: 12px;
  font-size: 18px;
  font-weight: 800;
  line-height: 1.2;
}

.detail-row {
  display: grid;
  grid-template-columns: 90px minmax(0, 1fr);
  gap: 10px;
  padding: 8px 0;
  border-top: 1px solid #e3e8e4;
  font-size: 12px;
}

.detail-row text:first-child {
  color: #64716a;
  font-weight: 800;
}

.drawer-input {
  height: 42px;
  margin-bottom: 10px;
  padding: 0 11px;
  border: 1px solid #d7ded8;
  border-radius: 8px;
  background: #ffffff;
  font-size: 13px;
  line-height: 42px;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-top: 10px;
}

.tag {
  padding: 5px 8px;
  border-radius: 999px;
  background: #e4ece7;
  color: #163f38;
  font-size: 11px;
  font-weight: 800;
}

.drawer-actions {
  display: flex;
  gap: 10px;
  margin-top: 12px;
}

.detail-action,
.secondary-action {
  margin-top: 12px;
  border-radius: 8px;
  font-size: 13px;
  line-height: 38px;
}

.drawer-actions button {
  flex: 1;
  margin-top: 0;
}

.detail-action {
  background: #163f38;
  color: #ffffff;
}

.secondary-action {
  background: #e7efea;
  color: #163f38;
}
