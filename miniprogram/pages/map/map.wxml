<view class="map-page">
  <map
    class="travel-map"
    latitude="{{mapCenter.latitude}}"
    longitude="{{mapCenter.longitude}}"
    scale="{{mapScale}}"
    markers="{{markers}}"
    polygons="{{polygons}}"
    polyline="{{polylines}}"
    show-location
    enable-zoom
    enable-scroll
    bindmarkertap="toggleMarkerRegion"
    bindtap="handleMapTap"
  ></map>

  <view class="map-panel">
    <view class="map-panel-row">
      <view class="map-controls">
        <picker range="{{levelLabels}}" value="{{levelIndex}}" bindchange="changeLevel">
          <view class="control-picker">{{levelLabels[levelIndex]}}⌄</view>
        </picker>
        <picker
          wx:if="{{levelIndex === 2}}"
          range="{{provinceNames}}"
          value="{{provinceIndex}}"
          bindchange="changeProvince"
        >
          <view class="control-picker">{{provinceNames[provinceIndex]}}⌄</view>
        </picker>
      </view>
      <button class="light-button {{addMode ? 'cancel' : ''}}" bindtap="toggleAddMode">
        {{addMode ? '取消添加' : '添加打卡点'}}
      </button>
    </view>

    <view class="map-summary">
      <view class="summary-item">
        <text class="summary-value">{{visitedCount}}</text>
        <text class="summary-label">{{levelSummary}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{checkinCount}}</text>
        <text class="summary-label" bindtap="openCheckins">我的打卡 ›</text>
      </view>
    </view>
    <view class="overlay-toggles">
      <view
        wx:for="{{overlayOptions}}"
        wx:key="key"
        class="overlay-toggle {{item.checked ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="toggleOverlay"
      >{{item.label}}</view>
    </view>
  </view>

  <scroll-view wx:if="{{!addMode && !selectedCheckin}}" class="province-strip" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="province-strip-inner">
      <view
        wx:for="{{stripItems}}"
        wx:key="id"
        class="province-chip {{item.visited ? 'visited' : ''}}"
        data-id="{{item.id}}"
        bindtap="toggleStripRegion"
      >{{item.name}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{addMode && !pendingPoint}}" class="map-mode-tip">请在地图上点击要打卡的位置</view>

  <view wx:if="{{pendingPoint}}" class="point-sheet">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">添加地图打卡</text>
        <text class="sheet-area">{{pendingPoint.area}}</text>
      </view>
      <text class="sheet-close" bindtap="cancelPoint">×</text>
    </view>
    <input
      class="sheet-input"
      value="{{draftName}}"
      placeholder="地点名称"
      maxlength="40"
      bindinput="updateDraftName"
    />
    <picker mode="date" value="{{draftDate}}" bindchange="updateDraftDate">
      <view class="sheet-input">{{draftDate || '选择日期（可选）'}}</view>
    </picker>
    <view class="sheet-actions">
      <button class="secondary-button" bindtap="cancelPoint">取消</button>
      <button class="primary-button" bindtap="saveMapCheckin">保存打卡</button>
    </view>
  </view>

  <view wx:if="{{selectedCheckin && !pendingPoint}}" class="point-sheet compact-sheet">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">{{selectedCheckin.name}}</text>
        <text class="sheet-area">
          {{selectedCheckin.date || '未填写日期'}} · {{selectedCheckin.latitude}}, {{selectedCheckin.longitude}}
        </text>
      </view>
      <text class="sheet-close" bindtap="closeCheckinDetail">×</text>
    </view>
    <view class="sheet-actions">
      <button class="danger-button" bindtap="deleteSelectedCheckin">删除打卡点</button>
      <button class="secondary-button" bindtap="openCheckins">查看全部</button>
    </view>
  </view>
</view>
