<view class="map-app">
  <map
    class="travel-map"
    latitude="{{mapCenter.latitude}}"
    longitude="{{mapCenter.longitude}}"
    scale="{{mapScale}}"
    markers="{{markers}}"
    polygons="{{polygons}}"
    polyline="{{polylines}}"
    show-location
    enable-zoom
    enable-scroll
    enable-satellite="{{enableSatellite}}"
    bindmarkertap="showMarkerDetail"
    bindtap="handleMapTap"
  ></map>

  <view class="map-toolbar">
    <text class="map-title">我的全球旅行地图</text>
    <view class="map-control-panel">
      <picker range="{{providerLabels}}" value="{{providerIndex}}" bindchange="changeProvider">
        <view class="map-select">
          <text class="control-label">底图</text>
          <text class="control-value">{{providerLabels[providerIndex]}}⌄</text>
        </view>
      </picker>
      <picker range="{{levelLabels}}" value="{{levelIndex}}" bindchange="changeLevel">
        <view class="map-select">
          <text class="control-label">显示层级</text>
          <text class="control-value">{{levelLabels[levelIndex]}}⌄</text>
        </view>
      </picker>
      <button class="map-add-point {{addMode ? 'active' : ''}}" bindtap="toggleAddMode">
        {{addMode ? '取消添加' : '添加打卡点'}}
      </button>
      <view class="map-overlay-toggles">
        <view
          wx:for="{{overlayOptions}}"
          wx:key="key"
          class="overlay-toggle"
          data-key="{{item.key}}"
          bindtap="toggleOverlay"
        >
          <view class="checkbox {{item.checked ? 'checked' : ''}}">{{item.checked ? '✓' : ''}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{addMode && !pendingPoint}}" class="map-mode-tip">请点击地图选择打卡位置</view>

  <view wx:if="{{pendingPoint}}" class="map-drawer">
    <text class="drawer-close" bindtap="cancelPoint">×</text>
    <text class="eyebrow">地图点击</text>
    <text class="drawer-title">添加打卡点</text>
    <input class="drawer-input" value="{{draftName}}" bindinput="updateDraftName" placeholder="地点名称" />
    <view class="detail-row">
      <text>坐标</text>
      <text>{{pendingPoint.coordinateText}}</text>
    </view>
    <view class="detail-row">
      <text>识别地区</text>
      <text>{{pendingPoint.area}}</text>
    </view>
    <picker mode="date" value="{{draftDate}}" bindchange="updateDraftDate">
      <view class="drawer-input">{{draftDate || '选择日期（可选）'}}</view>
    </picker>
    <view class="drawer-actions">
      <button class="detail-action" bindtap="saveMapCheckin">保存打卡</button>
      <button class="secondary-action" bindtap="cancelPoint">取消</button>
    </view>
  </view>

  <view wx:if="{{selectedDetail && !pendingPoint}}" class="map-drawer">
    <text class="drawer-close" bindtap="closeDetail">×</text>
    <text class="eyebrow">{{selectedDetail.eyebrow}}</text>
    <text class="drawer-title">{{selectedDetail.name}}</text>
    <view wx:for="{{selectedDetail.rows}}" wx:key="label" class="detail-row">
      <text>{{item.label}}</text>
      <text>{{item.value}}</text>
    </view>
    <view wx:if="{{selectedDetail.tags.length}}" class="tag-row">
      <text wx:for="{{selectedDetail.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <button
      wx:if="{{selectedDetail.action}}"
      class="detail-action"
      bindtap="toggleSelectedDetail"
    >{{selectedDetail.action}}</button>
  </view>
</view>
