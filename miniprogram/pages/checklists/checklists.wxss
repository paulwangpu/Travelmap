.content-page {
  min-height: 100%;
  padding: calc(env(safe-area-inset-top) + 72rpx) 22rpx 22rpx;
  background: #f4f7f4;
}

.panel {
  padding: 22rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
}

.eyebrow,
.page-title {
  display: block;
}

.eyebrow {
  margin-bottom: 6rpx;
  color: #208765;
  font-size: 20rpx;
  font-weight: 800;
}

.page-title {
  margin-bottom: 20rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.achievement-list,
.group-list {
  display: grid;
  gap: 14rpx;
}

.achievement-group,
.checklist-group {
  overflow: hidden;
  border: 1rpx solid #d7ded8;
  border-radius: 8rpx;
  background: #ffffff;
}

.section-summary,
.group-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  font-weight: 900;
}

.section-summary {
  min-height: 76rpx;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #d7ded8;
  background: #f8fbf9;
  font-size: 25rpx;
}

.section-content {
  padding: 14rpx;
}

.checklist-health {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.checklist-health text {
  padding: 6rpx 10rpx;
  border: 1rpx solid #d7ded8;
  border-radius: 999rpx;
  background: #f8faf8;
  color: #64716a;
  font-size: 19rpx;
}

.group-summary {
  min-height: 64rpx;
  padding: 0 14rpx;
  font-size: 23rpx;
}

.check-chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 9rpx;
  padding: 12rpx 14rpx 14rpx;
  border-top: 1rpx solid #e3e8e4;
}

.check-chip {
  width: auto;
  max-width: 100%;
  min-height: 56rpx;
  margin: 0;
  padding: 8rpx 14rpx;
  overflow: hidden;
  border: 1rpx solid #d7ded8;
  border-radius: 999rpx;
  background: #f7faf8;
  color: #18201c;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
}

.check-chip::after {
  border: 0;
}

.check-chip.done {
  border-color: #8cb69a;
  background: #eaf6ee;
  color: #163f38;
}
