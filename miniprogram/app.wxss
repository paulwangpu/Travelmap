page {
  height: 100%;
  background: #f4f7f4;
  color: #18201c;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
picker,
map {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

button::after {
  border: 0;
}

.page {
  min-height: 100%;
  padding: 24rpx;
}

.page-title {
  margin: 0 0 20rpx;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-title {
  margin: 0;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.muted {
  color: #6c7871;
}

.small {
  font-size: 24rpx;
}

.panel {
  padding: 24rpx;
  border: 1rpx solid #dce3de;
  border-radius: 14rpx;
  background: #ffffff;
}

.primary-button {
  background: #16735b;
  color: #ffffff;
}

.secondary-button {
  background: #eef5f1;
  color: #175f4e;
}

.danger-button {
  background: #fff1ef;
  color: #a43e32;
}

.empty {
  padding: 60rpx 24rpx;
  color: #718078;
  text-align: center;
}
